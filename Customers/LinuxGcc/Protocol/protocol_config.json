{
  "customer": "LinuxGcc",
  "version": 1.1,
  "releaseDate": "2026-04-06",
  "protocol": {
    "use": true,
    "activeProtocol": "protocolOrionTlv",
    "protocols": {
      "protocolRigelMq": {
        "use": false,
        "name": "protocolRigelMq",
        "linkedSensorName": "electricityMeter",
        "description": "Rigel MQTT-JSON-Session based protocol for IoT meter gateway",
        "connection": {
          "type": "mqtt",
          "mqttBroker": {
            "ipAddr": "127.0.0.1",
            "port": 1883,
            "username": "ZDUser",
            "password": "ZDUserPass"
          },
          "deviceIpAddr": "127.0.0.1",
          "pullPort": 2622
        },

        "protocolFunc": {
          "sourcePath": "AppZMeterGw/Services/Protocol/inc/AppProtocolRigelMq.h",
          "initFunc": "appProtocolRigelMqInit",
          "startFunc": "appProtocolRigelMqStart",
          "stopFunc": "appProtocolRigelMqStop",
          "putIncomingFunc": "appProtocolRigelMqPutIncomingMessage"
        }
      },
      "protocolOrionTlv": {
        "use": true,
        "name": "protocolOrionTlv",
        "linkedSensorName": "electricityMeter",
        "description": "Orion TLV-TCP-Session based protocol for IoT meter gateway",
        "connection": {
          "type": "tcp",
          "serverIpAddr": "127.0.0.1",
          "pushPort": 1883,
          "deviceIpAddr": "127.0.0.1",
          "pullPort": 2622
        },
        "protocolFunc": {
          "sourcePath": "AppZMeterGw/Services/Protocol/inc/AppProtocolOrionTLV.h",
          "initFunc": "appProtocolOrionTLVInit",
          "startFunc": "appProtocolOrionTLVStart",
          "stopFunc": "appProtocolOrionTLVStop",
          "putIncomingFunc": "appProtocolOrionTLVPutIncomingMessage"
        }
      },
      "protocolZD": {
        "use": false,
        "name": "protocolZD",
        "linkedSensorName": "electricityMeter",
        "description": "ZD JSON-TCP based protocol for IoT meter gateway",
        "connection": {
          "type": "tcp",
          "serverIpAddr": "127.0.0.1",
          "pushPort": 1883,
          "deviceIpAddr": "127.0.0.1",
          "pullPort": 2622
        },
        "protocolFunc": {
          "sourcePath": "AppZMeterGw/Services/Protocol/inc/AppProtocolZD.h",
          "initFunc": "appProtocolZDInit",
          "startFunc": "appProtocolZDStart",
          "stopFunc": "appProtocolZDStop",
          "putIncomingFunc": "appProtocolZDPutIncomingMessage"
        }
      },
      "protocolMetallix": {
        "use": false,
        "name": "protocolMetallix",
        "linkedSensorName": "electricityMeter",
        "description": "Metallix TLV-TCP based protocol for IoT meter gateway",
        "connection": {
          "type": "tcp",
          "serverIpAddr": "127.0.0.1",
          "pushPort": 1883,
          "deviceIpAddr": "127.0.0.1",
          "pullPort": 2622
        },
        "protocolFunc": {
          "sourcePath": "AppZMeterGw/Services/Protocol/inc/AppProtocolMetallixTLV.h",
          "initFunc": "appProtocolMetallixTLVInit",
          "startFunc": "appProtocolMetallixTLVStart",
          "stopFunc": "appProtocolMetallixTLVStop",
          "putIncomingFunc": "appProtocolMetallixTLVPutIncomingMessage"
        }
      }
    },
    "sensors":[
      {
        "name": "electricityMeter",
        "type": "meter",
        "description": "Electricity Energy Meter",
        "drvSrcPath": "AppZMeterGw/Services/Protocol/Test_Server/MeterTcpComm.h",
        "uartLine": "UART_COMM_LINE_1",
        "initFunc": "meterTcpCommInit",
        "deinitFunc": "meterTcpCommDeinit",
        "readFunc": "meterTcpCommReceive",
        "writeFunc": "meterTcpCommSend",
        "setBaudrateFunc": "meterTcpCommSetBaudrate"
      },
      {
        "name": "sensor1",
        "type": "temperature",
        "description": "Temperature sensor",
        "drvSrcPath": "Driver/Sensors/inc/SensorTemperature.h",
        "readFunc": "sensorTemperatureRead",
        "writeFunc": "sensorTemperatureWrite",
        "eraseFunc": "sensorTemperatureErase",
        "syncFunc": "sensorTemperatureSync"
      },
      {
        "name": "sensor2",
        "type": "humidity",
        "description": "Humidity sensor",
        "drvSrcPath": "Driver/Sensors/inc/SensorHumidity.h",
        "readFunc": "sensorHumidityRead",
        "writeFunc": "sensorHumidityWrite",
        "eraseFunc": "sensorHumidityErase",
        "syncFunc": "sensorHumiditySync"
      }
    ]
  }
}