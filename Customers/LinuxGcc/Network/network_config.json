        "driverConfig": {
          "spiDriver": "spiDriver",
          "spiDriverPath": "Drivers/ENC28J60/enc28j60_spi_driver.h",
          "extIntDriver": "extIntDriver",
          "extIntDriverPath": "Drivers/ENC28J60/enc28j60/enc28j60_extint_driver.h"
        }
      }       
      }
    ],
    "gsmInterfaces": [
    {
      "use": false,
      "ifname": "ppp0",
      "type": "ppp",
      "description": "PPP interface",
      "appManager": "Services/Network/src/GsmConn_Comm.c",
      "gsmModemConfig": {
        "__comment__": "set null to pin code is not used",
        "pinCode": null,
        "apn": "zd.iot",
